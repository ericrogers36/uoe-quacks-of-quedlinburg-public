\ProvidesPackage{beamercolorthemeGeminiUOE}

% ================
% COLOURS
% ================

% Colors from https://www.erp.ac.uk/University_Logo_Guidelines.pdf

\definecolor{uoenavy}{cmyk}{1.0, 0.72, 0.0, 0.56}
\definecolor{noteablered}{cmyk}{0,0.64,0.45,0.33}
\definecolor{uoered}{cmyk}{0.0, 1.00, 0.39, 0.00}

% Extra colors
\definecolor{lightgray}{RGB}{240, 240, 240}
\definecolor{lightorange}{RGB}{255, 245, 242}


% ================
% THEME COLOURS
% ================


% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=black}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=noteablered}

\setbeamercolor{headline}{fg=black, bg=lightgray}

% Titles

\setbeamercolor{frametitle}{fg=noteablered}

% Blocks
\setbeamercolor{block title}{fg=noteablered, bg=white}
\setbeamercolor{block separator}{bg=black}
\setbeamercolor{block body}{fg=black, bg=white}

\setbeamercolor{block alerted title}{fg=noteablered, bg=lightorange}
\setbeamercolor{block alerted body}{fg=black, bg=lightorange}

\setbeamercolor{block example title}{fg=noteablered, bg=lightgray}
\setbeamercolor{block example body}{fg=black, bg=lightgray}


\setbeamercolor{heading}{fg=black}
\setbeamercolor{item}{fg=noteablered}

